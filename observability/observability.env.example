# Athena Observability Adapter runtime env

# Enable or disable local OTel/OpenLIT bootstrap.
ATHENA_OBSERVABILITY_ENABLED=true

# Adapter service bind.
ATHENA_OBSERVABILITY_HOST=127.0.0.1
ATHENA_OBSERVABILITY_PORT=8090

# OTLP export target for SigNoz.
# Self-hosted SigNoz usually exposes:
# - HTTP: http://127.0.0.1:4318
# - gRPC: http://127.0.0.1:4317
ATHENA_OBSERVABILITY_OTLP_ENDPOINT=http://127.0.0.1:4318
ATHENA_OBSERVABILITY_OTLP_PROTOCOL=http/protobuf
ATHENA_OBSERVABILITY_OTLP_HEADERS=

# OpenLIT is optional. When true and package is installed, bootstrap calls
# openlit.init() on top of OTel setup.
ATHENA_OBSERVABILITY_USE_OPENLIT=true

# Metrics can be noisy on small local machines; turn off if needed.
ATHENA_OBSERVABILITY_METRICS_ENABLED=true

# Environment/resource labeling.
ATHENA_OBSERVABILITY_ENVIRONMENT=local

