# AutoGLM / OpenAI API 配置
# 复制此文件为 .env 并填写实际值

# API 密钥（必填）
AUTOGLM_API_KEY=

# API 基础 URL（必填）
# 示例: https://api.openai.com/v1 或自托管服务地址
AUTOGLM_BASE_URL=

# 模型名称
# 示例: gpt-4, gpt-3.5-turbo, claude-3-opus
AUTOGLM_MODEL=gpt-4

# 请求超时（秒）
AUTOGLM_TIMEOUT=60

# 是否使用 Mock 模式（true/false）
# 默认为 true，不调用真实 API
AUTOGLM_USE_MOCK=true

# ADB 设备序列号（可选）
# 如果不填，将自动选择第一个设备
ADB_SERIAL=

# 日志级别
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ========================================
# Vision / OCR 配置（阶段 8 新增）
# ========================================

# 是否启用 OCR/Grounding（true/false）
# 默认为 true，启用视觉增强
VISION_USE_OCR=true

# OCR Provider
# 可选: mock（测试用）, primary（EasyOCR）
# 注意: primary 需要安装 easyocr
VISION_OCR_PROVIDER=mock

# 文本匹配阈值（0.0-1.0）
# 低于此阈值的匹配将被忽略
VISION_TEXT_MATCH_THRESHOLD=0.75

# 最大候选目标数量
VISION_MAX_CANDIDATES=5

# 屏幕尺寸（用于安全边距计算）
# 默认: Z Flip3 1080x2640
VISION_SCREEN_WIDTH=1080
VISION_SCREEN_HEIGHT=2640

# ========================================
# State Detection 配置（阶段 11.5 新增）
# ========================================

# 状态置信度阈值（0.0-1.0）
# 低于此阈值时使用保守策略（先回到主屏幕）
# 默认: 0.65
STATE_CONFIDENCE_THRESHOLD=0.65

# 是否使用历史动作信号（true/false）
# 根据上一步动作推断当前状态
# 默认: true
STATE_USE_HISTORY_SIGNAL=true

# 是否启用动作后状态验证（true/false）
# 执行关键动作后重新检测状态
# 默认: true
STATE_ENABLE_POST_ACTION_CHECK=true

# ========================================
# MiniCPM Vision 配置（阶段 13 新增）
# ========================================

# 是否启用 MiniCPM 视觉增强（true/false）
# 默认为 false，不启用
VISION_USE_MINICPM=false

# MiniCPM 运行模式
# 可选: mock（测试用）, remote（远程 API）, local_api（本地 API）
# 默认: mock
MINICPM_MODE=mock

# MiniCPM API 基础 URL
# 例如: https://api.example.com/v1
MINICPM_BASE_URL=

# MiniCPM 模型名称
# 默认: MiniCPM-V
MINICPM_MODEL=MiniCPM-V

# MiniCPM 请求超时（秒）
# 默认: 60
MINICPM_TIMEOUT=60

# MiniCPM 置信度阈值（0.0-1.0）
# MiniCPM 结果高于此值时使用
# 默认: 0.70
MINICPM_CONFIDENCE_THRESHOLD=0.70

# OCR 高置信度阈值（0.0-1.0）
# OCR 结果高于此值时不调用 MiniCPM
# 默认: 0.85
OCR_HIGH_CONFIDENCE_THRESHOLD=0.85
