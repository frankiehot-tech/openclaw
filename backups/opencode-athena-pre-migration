def get_provider_endpoint(task_kind=None, request_id=None):
    """从Athena Provider Registry获取provider端点和信息

    Args:
        task_kind: 任务类型 (debug/testing/general等)
        request_id: 可选请求ID，用于实验分配

    Returns:
        tuple: (provider_id, base_url, model, api_key) 或 None
    """
    try:
        setup_athena_imports()

        # 导入provider注册表
        from agent.core.provider_registry import get_registry

        registry = get_registry()

        # 根据任务类型解析provider
        if task_kind:
            provider_id, model_id = registry.resolve_provider_for_task(task_kind, request_id)
            print(f"🔍 根据任务类型 '{task_kind}' 选择 provider: {provider_id}, model: {model_id}", file=sys.stderr)
        else:
            # 使用默认provider
            provider_id, model_id = registry.get_default_model()
            print(f"🔍 使用默认 provider: {provider_id}, model: {model_id}", file=sys.stderr)

        provider = registry.get_provider(provider_id)
        if not provider:
            print(f"❌ 警告：无法从Athena获取provider '{provider_id}' 信息", file=sys.stderr)
            return None

        print(f"✅ 从Athena获取 {provider.label} 配置：", file=sys.stderr)
        print(f"   Provider ID: {provider.id}", file=sys.stderr)
        print(f"   标签: {provider.label}", file=sys.stderr)
        print(f"   基础URL: {provider.base_url}", file=sys.stderr)
        print(f"   默认模型: {model_id}", file=sys.stderr)
        print(f"   成本模式: {provider.cost_mode}", file=sys.stderr)

        # 检查API密钥
        api_key = registry.get_auth_key(provider_id)
        if api_key:
            print(f"✅ API密钥已配置: {api_key[:8]}...{api_key[-8:]}", file=sys.stderr)
        else:
            print(f"⚠️  警告：{provider.auth_env_key} 环境变量未设置", file=sys.stderr)

        return provider_id, provider.base_url, model_id, api_key

    except ImportError as e:
        print(f"❌ 导入Athena模块失败: {e}", file=sys.stderr)
        print(f"   请检查Athena项目路径: {ATHENA_PROJECT_ROOT}", file=sys.stderr)
        print(f"⚠️  使用默认DashScope端点", file=sys.stderr)
        return "dashscope", "https://dashscope.aliyuncs.com/compatible-mode/v1", "qwen3.5-plus", os.environ.get("DASHSCOPE_API_KEY")
    except Exception as e:
        print(f"❌ 获取provider端点时出错: {e}", file=sys.stderr)
        print(f"⚠️  使用默认DashScope端点", file=sys.stderr)
        return "dashscope", "https://dashscope.aliyuncs.com/compatible-mode/v1", "qwen3.5-plus", os.environ.get("DASHSCOPE_API_KEY")

def get_opencode_binary():
    """获取真正的opencode二进制文件路径"""
    # 可能的路径（按优先级）
    possible_paths = [
        # 直接二进制文件
        "/opt/homebrew/lib/node_modules/opencode-ai/node_modules/opencode-darwin-arm64/bin/opencode",
        # Node.js包装器
        "/opt/homebrew/bin/opencode",
        # 全局查找
        "/usr/local/bin/opencode",
        "/usr/bin/opencode",
    ]

    for path in possible_paths:
        if os.path.exists(path) and os.access(path, os.X_OK):
            print(f"✅ 找到opencode二进制文件: {path}", file=sys.stderr)
            return path

    # 如果找不到，尝试使用which命令
    try:
        result = subprocess.run(["which", "opencode"], capture_output=True, text=True)
        if result.returncode == 0 and result.stdout.strip():
            path = result.stdout.strip()
            if os.path.exists(path):
                print(f"✅ 通过which找到opencode: {path}", file=sys.stderr)
                return path
    except:
        pass

    print("❌ 错误：找不到opencode二进制文件", file=sys.stderr)
    print("   请确保opencode已安装", file=sys.stderr)
    return None

def set_environment_variables(provider_info):
    """设置环境变量以使用指定的provider端点

    Args:
        provider_info: (provider_id, base_url, model, api_key) 元组

    Returns:
        设置了环境变量的env字典
    """
    env = os.environ.copy()

    if not provider_info:
        print("⚠️  警告：未提供provider信息，使用默认环境变量", file=sys.stderr)
        return env

    provider_id, base_url, model, api_key = provider_info

    print(f"🔧 设置 {provider_id} 环境变量：", file=sys.stderr)
    print(f"   基础URL: {base_url}", file=sys.stderr)
    print(f"   模型: {model}", file=sys.stderr)

    # 设置通用环境变量
    env["ATHENA_PROVIDER_ID"] = provider_id
    env["ATHENA_MODEL"] = model

    # 设置OpenAI兼容环境变量（大多数provider使用OpenAI兼容API）
    env["OPENAI_BASE_URL"] = base_url
    env["OPENAI_API_KEY"] = api_key or ""
    env["OPENAI_MODEL"] = model

    # 设置Anthropic兼容环境变量（OpenCode使用这个）
    # 注意：大多数中国LLM服务只提供OpenAI兼容端点，不提供Anthropic兼容
    # 因此我们将ANTHROPIC_BASE_URL设置为OpenAI兼容端点
    env["ANTHROPIC_BASE_URL"] = base_url
    env["ANTHROPIC_MODEL"] = model
    if api_key:
        env["ANTHROPIC_AUTH_TOKEN"] = api_key

    # Provider特定的环境变量
    if provider_id == "dashscope":
        # DashScope特定的环境变量
        env["DASHSCOPE_API_BASE_URL"] = base_url
        env["DASHSCOPE_API_KEY"] = api_key or ""
        env["DASHSCOPE_MODEL"] = model
        env["OPENCODE_ALIBABA_BASE_URL"] = base_url
        env["ALIBABA_API_BASE_URL"] = base_url

        # 区域设置
        env["DASHSCOPE_REGION"] = "cn"
        env["ALIBABA_CLOUD_REGION_ID"] = "cn-hangzhou"
        env["ALIBABA_REGION"] = "cn"

        # 基础URL（不带路径）
        if "dashscope.aliyuncs.com" in base_url:
            base_host = "https://dashscope.aliyuncs.com"
            env["DASHSCOPE_BASE_URL"] = base_host
            env["ALIBABA_BASE_URL"] = base_host

        print(f"✅ 已设置DashScope环境变量", file=sys.stderr)

    elif provider_id == "deepseek":
        # DeepSeek特定的环境变量
        env["DEEPSEEK_API_BASE_URL"] = base_url
        env["DEEPSEEK_API_KEY"] = api_key or ""
        env["DEEPSEEK_MODEL"] = model

        print(f"✅ 已设置DeepSeek环境变量", file=sys.stderr)
        print(f"💰 成本优势：DeepSeek成本仅为DashScope的12.5%", file=sys.stderr)

    elif provider_id == "minimax":
        # MiniMax特定的环境变量
        env["MINIMAX_API_BASE_URL"] = base_url
        env["MINIMAX_API_KEY"] = api_key or ""
        env["MINIMAX_MODEL"] = model

        print(f"✅ 已设置MiniMax环境变量", file=sys.stderr)

    elif provider_id == "kimi":
        # Kimi特定的环境变量
        env["MOONSHOT_API_BASE_URL"] = base_url
        env["MOONSHOT_API_KEY"] = api_key or ""
        env["MOONSHOT_MODEL"] = model

        print(f"✅ 已设置Kimi环境变量", file=sys.stderr)

    elif provider_id == "glm":
        # GLM特定的环境变量
        env["ZHIPU_API_BASE_URL"] = base_url
        env["ZHIPU_API_KEY"] = api_key or ""
        env["ZHIPU_MODEL"] = model

        print(f"✅ 已设置GLM环境变量", file=sys.stderr)

    elif provider_id == "ollama_local":
        # Ollama本地特定的环境变量
        env["OLLAMA_BASE_URL"] = base_url
        env["OLLAMA_MODEL"] = model

        print(f"✅ 已设置Ollama本地环境变量", file=sys.stderr)

    # 代理相关设置 - 确保不代理中国站域名
    no_proxy = env.get("NO_PROXY", "")

    # 添加provider域名到NO_PROXY
    domains_to_exclude = []
    if "dashscope.aliyuncs.com" in base_url:
        domains_to_exclude.append("dashscope.aliyuncs.com")
        domains_to_exclude.append("dashscope-intl.aliyuncs.com")
    elif "api.deepseek.com" in base_url:
        domains_to_exclude.append("api.deepseek.com")
    elif "api.minimax.chat" in base_url:
        domains_to_exclude.append("api.minimax.chat")
    elif "api.moonshot.cn" in base_url:
        domains_to_exclude.append("api.moonshot.cn")
    elif "open.bigmodel.cn" in base_url:
        domains_to_exclude.append("open.bigmodel.cn")

    for domain in domains_to_exclude:
        if domain not in no_proxy:
            env["NO_PROXY"] = no_proxy + ("," if no_proxy else "") + domain
            print(f"✅ 设置NO_PROXY排除 {domain}", file=sys.stderr)

    return env

def parse_arguments():
    """解析命令行参数"""
    # 我们不解析具体参数，只是传递所有参数给opencode
    # 但我们可以检查是否有--help或特殊参数
    parser = argparse.ArgumentParser(
        description="opencode包装器 - 集成Athena多LLM路由",
        add_help=False  # 不自动添加--help，我们会传递给opencode
    )

    # 添加包装器特定的参数
    parser.add_argument("--athena-debug", action="store_true",
                       help="显示Athena调试信息")
    parser.add_argument("--no-athena", action="store_true",
                       help="不使用Athena配置，直接调用opencode")
    parser.add_argument("--env-only", action="store_true",
                       help="只显示环境变量，不执行opencode")
    parser.add_argument("--dry-run", action="store_true",
                       help="模拟执行，显示命令但不实际运行")
    parser.add_argument("--task-kind", type=str,
                       help="任务类型 (debug/testing/general等)，用于选择LLM provider")

    # 解析已知参数，剩余参数传递给opencode
    args, remaining_args = parser.parse_known_args()

    return args, remaining_args

def extract_user_message_from_prompt(prompt):
    """从OpenCode提示中提取用户消息

    OpenCode提示格式包含系统提示和任务说明。
    用户消息通常在"原始消息"部分或最后。
    """
    # 如果是工程实施方案，返回整个提示（最大8000字符）
    if "engineering-plan" in prompt:
        print(f"🔧 检测到工程实施方案，使用完整提示（最大8000字符）", file=sys.stderr)
        print(f"🔧 原始提示长度: {len(prompt)}", file=sys.stderr)
        # 尝试提取核心需求部分
        import re
        core_pattern = r'## 核心需求摘要\s*\n(.*?)(?=\n## |\n---|\n\*\*\*|$)'
        match = re.search(core_pattern, prompt, re.DOTALL | re.IGNORECASE)
        if match:
            core_content = match.group(1).strip()
            print(f"🔧 提取到核心需求，长度: {len(core_content)}", file=sys.stderr)
            # 返回核心需求 + 前1000字符的上下文
            context = prompt[:1000] if len(prompt) > 1000 else prompt
            return f"{context}\n\n核心需求:\n{core_content}"[:8000].strip()
        else:
            print(f"🔧 未找到核心需求，使用前8000字符", file=sys.stderr)
            return prompt[:8000].strip()

    # 查找"原始消息"部分
    import re

    # 模式1：查找```包围的原始消息
    pattern1 = r'```\s*(.*?)\s*```'
    matches = re.findall(pattern1, prompt, re.DOTALL)
    if matches:
        # 取最后一个```包围的内容（通常是原始消息）
        raw_message = matches[-1].strip()
        # 提取第一行（用户消息）
        lines = raw_message.split('\n')
        for line in lines:
            if line.strip() and not line.startswith('此请求通过'):
                return line.strip()

    # 模式2：查找"用户聊天消息:"模式
    pattern2 = r'用户聊天消息:\s*(.*)'
    match = re.search(pattern2, prompt)
    if match:
        return match.group(1).strip()

    # 模式3：查找"用户消息:"模式
    pattern3 = r'用户消息:\s*(.*)'
    match = re.search(pattern3, prompt)
    if match:
        return match.group(1).strip()

    # 如果找不到，返回原始提示的前200字符
    print(f"⚠️  警告：无法从提示中提取用户消息，使用前200字符", file=sys.stderr)
    return prompt[:200].strip()

