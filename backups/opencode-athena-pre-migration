                print(f"🔧 环境变量已设置: MINIMAX_API_BASE_URL={env.get('MINIMAX_API_BASE_URL', '未设置')}", file=sys.stderr)
            elif provider_id == "kimi":
                print(f"🔧 环境变量已设置: MOONSHOT_API_BASE_URL={env.get('MOONSHOT_API_BASE_URL', '未设置')}", file=sys.stderr)
