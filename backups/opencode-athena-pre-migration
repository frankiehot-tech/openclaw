def use_provider_alternative(opencode_args, provider_id="dashscope", model=None):
    """使用provider替代方案（如claude-qwen-alt.sh）

    Returns:
        tuple: (command, prompt_text, model_name) 或 None
    """
    script_path = get_provider_script(provider_id)

    if not script_path:
        print(f"⚠️  {provider_id} 不支持替代脚本，回退到原始opencode", file=sys.stderr)
        return None

    # 解析OpenCode参数，转换为脚本参数
    provider_cmd = [script_path]
    if not model:
        model = "qwen3.6-plus" if provider_id == "dashscope" else "deepseek-chat"
    prompt = ""
    original_prompt = ""

    # 调试输出
    print(f"🔍 use_provider_alternative: 解析参数 {opencode_args}, provider={provider_id}", file=sys.stderr)

    i = 0
    while i < len(opencode_args):
        arg = opencode_args[i]
        print(f"🔍 处理参数[{i}]: '{arg[:50]}{'...' if len(arg) > 50 else ''}'", file=sys.stderr)

        if arg == "--model" and i + 1 < len(opencode_args):
            model_arg = opencode_args[i + 1]
            # 转换模型名称：alibaba/qwen3.5-plus -> qwen3.5-plus
            if model_arg.startswith("alibaba/"):
                model = model_arg[8:]  # 移除"alibaba/"前缀
            else:
                model = model_arg
            print(f"🔍 识别模型参数: {model}", file=sys.stderr)
            i += 2
        elif arg == "--title" and i + 1 < len(opencode_args):
            # 忽略标题参数
            print(f"🔍 忽略标题参数: {opencode_args[i+1][:50]}", file=sys.stderr)
            i += 2
        elif arg == "--format" and i + 1 < len(opencode_args):
            # 忽略格式参数
            print(f"🔍 忽略格式参数: {opencode_args[i+1]}", file=sys.stderr)
            i += 2
        elif arg.startswith("-"):
            # 忽略其他选项
            print(f"🔍 忽略选项: {arg}", file=sys.stderr)
            i += 1
        else:
            # 这是提示文本
            original_prompt = arg
            print(f"🔍 识别为提示文本，原始长度: {len(original_prompt)}", file=sys.stderr)

            # 从提示中提取用户消息
            prompt = extract_user_message_from_prompt(original_prompt)
            print(f"🔍 提取的用户消息: '{prompt[:100]}{'...' if len(prompt) > 100 else ''}'", file=sys.stderr)
            print(f"🔍 提取后长度: {len(prompt)}", file=sys.stderr)
            i += 1

    if not prompt:
        print("❌ 错误：未提供提示文本", file=sys.stderr)
        return None

    provider_cmd.extend(["-m", model, prompt])
    print(f"🔍 Provider命令: {provider_cmd[:3]}... (提示长度: {len(prompt)})", file=sys.stderr)
    return (provider_cmd, prompt, model)

def extract_input_from_args(args_list):
    """从OpenCode参数列表中提取输入文本"""
    if not args_list:
        return ""

    # OpenCode参数格式通常为：["run", "--model", "model_name", "prompt_text"]
    # 或者使用provider替代脚本时：["script_path", "-m", "model_name", "prompt_text"]

    # 查找非选项参数（不以-开头的参数）
    non_option_args = []
    i = 0
    while i < len(args_list):
        arg = args_list[i]
        if arg.startswith("-"):
            # 跳过选项和它的值
            i += 2 if i + 1 < len(args_list) else 1
        else:
            non_option_args.append(arg)
            i += 1

    # 最后一个非选项参数通常是提示文本
    if non_option_args:
        # 排除脚本路径（第一个参数）
        if len(non_option_args) > 1:
            return non_option_args[-1]
        elif len(non_option_args) == 1:
            # 检查第一个参数是否是脚本路径
            if args_list and args_list[0] == non_option_args[0]:
                # 可能是脚本路径，尝试检查是否是文件
                import os
                if os.path.exists(non_option_args[0]):
                    return ""  # 这是脚本路径，不是提示
                else:
                    return non_option_args[0]
            else:
                return non_option_args[0]

    return ""

def record_cost_if_enabled(cost_integration, cost_info, stdout, stderr, api_response=None, request_id=None, experiment_assignment=None):
    """如果成本跟踪启用，记录成本

    Args:
        cost_integration: 成本跟踪集成对象
        cost_info: 成本信息字典
        stdout: 标准输出
        stderr: 标准错误
        api_response: 可选的API响应
        request_id: 请求ID
        experiment_assignment: 可选的实验分配信息
    """
    if not cost_integration:
        return ""

    try:
        provider_id = cost_info.get("provider_id")
        model_id = cost_info.get("model_id")
        task_kind = cost_info.get("task_kind")
        input_text = cost_info.get("input_text")
        opencode_args = cost_info.get("opencode_args", [])
        use_provider_alt = cost_info.get("use_provider_alt", False)

        if not provider_id or provider_id == "unknown":
            print(f"⚠️  成本跟踪：未知provider，跳过记录", file=sys.stderr)
            return ""

        # 生成或使用提供的请求ID
        if request_id is None:
            import uuid
            from datetime import datetime
            request_id = f"req_{datetime.now().strftime('%Y%m%d_%H%M%S')}_{uuid.uuid4().hex[:8]}"
            print(f"💰 成本跟踪生成请求ID: {request_id}", file=sys.stderr)
        else:
            print(f"💰 成本跟踪使用提供请求ID: {request_id}", file=sys.stderr)

        # 根据不同的执行路径记录成本
        if use_provider_alt:
            # provider替代方案：从脚本输出估算成本
            print(f"💰 记录provider替代方案成本: {provider_id}/{model_id}", file=sys.stderr)

            # 尝试解析输出中的JSON响应（如果脚本返回JSON）
            output_text = stdout
            try:
                # 尝试从stdout解析JSON
                if stdout.strip():
                    json_start = stdout.find('{')
                    json_end = stdout.rfind('}') + 1
                    if json_start >= 0 and json_end > json_start:
                        json_str = stdout[json_start:json_end]
                        api_response = json.loads(json_str)
                        print(f"💰 从输出中解析到JSON响应", file=sys.stderr)
            except json.JSONDecodeError:
                api_response = None
                print(f"💰 输出不是JSON格式，使用原始输出", file=sys.stderr)

            if api_response and isinstance(api_response, dict):
                # 有API响应，尝试从中提取usage信息
                # 准备metadata
                metadata = {}
                if experiment_assignment:
                    metadata.update({
                        "experiment_assignment": experiment_assignment,
                        "experiment_id": experiment_assignment.get("experiment_id"),
                        "experiment_group": experiment_assignment.get("group_name")
                    })

                record_id = cost_integration.record_from_api_response(
                    provider_id=provider_id,
                    model_id=model_id,
                    task_kind=task_kind,
                    input_text=input_text,
                    api_response=api_response,
                    request_id=request_id,
                    metadata=metadata if metadata else None
                )
            else:
                # 没有API响应，使用输出文本估算
                # 准备metadata
                metadata = {}
                if experiment_assignment:
                    metadata.update({
                        "experiment_assignment": experiment_assignment,
                        "experiment_id": experiment_assignment.get("experiment_id"),
                        "experiment_group": experiment_assignment.get("group_name")
                    })

                record_id = cost_integration.record_provider_request(
                    provider_id=provider_id,
                    model_id=model_id,
                    task_kind=task_kind,
                    input_text=input_text,
                    output_text=stdout,
                    request_id=request_id,
                    estimated_tokens=True,
                    metadata=metadata if metadata else None
                )
        else:
            # 原始opencode执行：可能返回JSON响应
            print(f"💰 记录原始opencode成本: {provider_id}/{model_id}", file=sys.stderr)

            # 尝试从stdout解析JSON
            api_response = None
            try:
                if stdout.strip():
                    # 查找JSON开始和结束位置
                    json_start = stdout.find('{')
                    json_end = stdout.rfind('}') + 1
                    if json_start >= 0 and json_end > json_start:
                        json_str = stdout[json_start:json_end]
                        api_response = json.loads(json_str)
                        print(f"💰 从opencode输出中解析到JSON响应", file=sys.stderr)
            except json.JSONDecodeError:
                print(f"💰 opencode输出不是JSON格式", file=sys.stderr)

            if api_response and isinstance(api_response, dict):
                # 从API响应记录
                metadata = {}
                if experiment_assignment:
                    metadata.update({
                        "experiment_assignment": experiment_assignment,
                        "experiment_id": experiment_assignment.get("experiment_id"),
                        "experiment_group": experiment_assignment.get("group_name")
                    })

                record_id = cost_integration.record_from_api_response(
                    provider_id=provider_id,
                    model_id=model_id,
                    task_kind=task_kind,
                    input_text=input_text,
                    api_response=api_response,
                    request_id=request_id,
                    metadata=metadata if metadata else None
                )
            else:
                # 如果没有输入文本，尝试从参数中提取
                if not input_text and opencode_args:
                    # 简化：从opencode_args提取最后一个参数作为输入
                    for arg in reversed(opencode_args):
                        if arg and not arg.startswith('-'):
                            input_text = arg
                            break

                # 记录OpenCode执行
                metadata = {}
                if experiment_assignment:
                    metadata.update({
                        "experiment_assignment": experiment_assignment,
                        "experiment_id": experiment_assignment.get("experiment_id"),
                        "experiment_group": experiment_assignment.get("group_name")
                    })

                record_id = cost_integration.record_opencode_execution(
                    provider_id=provider_id,
                    model_id=model_id,
                    task_kind=task_kind,
                    opencode_args=opencode_args,
                    stdout=stdout,
                    stderr=stderr,
                    request_id=request_id,
                    metadata=metadata if metadata else None
                )

        if record_id:
            print(f"✅ 成本记录成功: {record_id}", file=sys.stderr)
        else:
            print(f"⚠️  成本记录失败", file=sys.stderr)

        return record_id if record_id else ""

    except Exception as e:
        print(f"❌ 成本记录过程中出错: {e}", file=sys.stderr)
        return ""

def main():
    """主函数"""
    print("=" * 60, file=sys.stderr)
    print("🚀 opencode包装器 - Athena多LLM路由集成", file=sys.stderr)
    print("=" * 60, file=sys.stderr)

