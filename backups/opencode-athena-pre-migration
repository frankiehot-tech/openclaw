            provider_id, base_url, model, api_key = provider_info

            # 尝试获取实验分配信息
            try:
                # 导入实验路由器
                sys.path.insert(0, "/Volumes/1TB-M2/openclaw")
                sys.path.insert(0, "/Volumes/1TB-M2/openclaw/mini-agent")
                from agent.core.experiment_router import get_experiment_router

                router = get_experiment_router()
                assignment = router.assign_to_experiment(args.task_kind, request_id)

                if assignment:
                    experiment_assignment = {
                        "experiment_id": assignment.experiment_id,
                        "group_name": assignment.group_name,
                        "metadata": assignment.metadata
                    }
                    print(f"🔬 实验分配: {assignment.experiment_id}/{assignment.group_name}", file=sys.stderr)
                else:
                    print(f"🔬 未分配到实验", file=sys.stderr)
            except ImportError:
                print(f"🔬 实验框架不可用，跳过实验分配记录", file=sys.stderr)
            except Exception as e:
                print(f"🔬 获取实验分配信息失败: {e}", file=sys.stderr)

        if provider_info and args.athena_debug:
            provider_id, base_url, model, api_key = provider_info
            print(f"🔧 根据任务类型 '{args.task_kind}' 选择 provider: {provider_id}", file=sys.stderr)
            print(f"🔧 基础URL: {base_url}", file=sys.stderr)
            print(f"🔧 模型: {model}", file=sys.stderr)
    else:
        print(f"🔧 跳过Athena配置，直接调用opencode", file=sys.stderr)

    # 设置环境变量
    env = set_environment_variables(provider_info)

    # 检查是否需要使用provider替代方案
    use_provider_alt = False
    if opencode_args and opencode_args[0] == "run":
        print(f"🔍 检测到run命令，参数: {opencode_args}", file=sys.stderr)

        # 检查是否为工程实施方案 - 对于工程实施方案，使用provider替代方案
        is_engineering_plan = any("engineering-plan" in str(arg) for arg in opencode_args)

        # 获取provider ID（如果provider_info存在）
        provider_id = "dashscope"  # 默认值
        model = None
        if provider_info:
            provider_id, base_url, model, api_key = provider_info
            print(f"🔧 使用Athena选择的provider: {provider_id}, model: {model}", file=sys.stderr)

        if is_engineering_plan:
            print(f"🔧 检测到工程实施方案，使用{provider_id}替代方案执行", file=sys.stderr)
            provider_alternative_result = use_provider_alternative(opencode_args[1:], provider_id, model)  # 跳过"run"
            if provider_alternative_result:
                use_provider_alt = True
                provider_cmd, prompt, model_name = provider_alternative_result
                cmd = provider_cmd
                print(f"🔧 使用{provider_id}替代方案执行工程实施方案: {' '.join(cmd[:3])}...", file=sys.stderr)
            else:
                print(f"⚠️  {provider_id}替代方案不可用，回退到原始opencode", file=sys.stderr)
                cmd = [opencode_binary] + opencode_args
        else:
            provider_alternative_result = use_provider_alternative(opencode_args[1:], provider_id, model)  # 跳过"run"
            if provider_alternative_result:
                use_provider_alt = True
                provider_cmd, prompt, model_name = provider_alternative_result
                cmd = provider_cmd
                print(f"🔧 使用{provider_id}替代方案: {' '.join(cmd[:3])}...", file=sys.stderr)
            else:
                print(f"⚠️  {provider_id}替代方案不可用，回退到原始opencode", file=sys.stderr)
                cmd = [opencode_binary] + opencode_args
    else:
        # 非run命令，使用原始opencode
        cmd = [opencode_binary] + opencode_args

    # 收集成本跟踪信息
    cost_tracking_info = {
        "provider_id": "unknown",
        "model_id": "unknown",
        "task_kind": args.task_kind,
        "input_text": "",
        "use_provider_alt": use_provider_alt,
        "opencode_args": opencode_args.copy() if opencode_args else []
    }

