    if provider_info:
        provider_id, base_url, model, api_key = provider_info
        cost_tracking_info["provider_id"] = provider_id
        cost_tracking_info["model_id"] = model

    # 提取输入文本
    input_text = ""
    if use_provider_alt:
        # 对于provider替代方案，尝试从命令中提取prompt
        # cmd变量已经设置，格式如: ["script_path", "-m", "model", "prompt"]
        # 查找最后一个参数作为prompt
        if cmd and len(cmd) > 3:
            # cmd格式通常是: ["/path/to/script.sh", "-m", "model_name", "prompt_text"]
            # 所以最后一个元素是prompt
            potential_prompt = cmd[-1]
            # 验证这不是一个选项（不以-开头）
            if not potential_prompt.startswith("-"):
                input_text = potential_prompt
    else:
        # 对于原始opencode，从参数中提取
        input_text = extract_input_from_args(opencode_args)

    cost_tracking_info["input_text"] = input_text

    if args.athena_debug:
        print(f"💰 成本跟踪信息收集完成:", file=sys.stderr)
        print(f"    provider: {cost_tracking_info['provider_id']}", file=sys.stderr)
        print(f"    模型: {cost_tracking_info['model_id']}", file=sys.stderr)
        print(f"    任务类型: {cost_tracking_info['task_kind']}", file=sys.stderr)
