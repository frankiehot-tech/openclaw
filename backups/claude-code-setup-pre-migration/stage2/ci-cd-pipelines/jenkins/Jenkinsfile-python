// Jenkins Pipeline for Python Projects
// 支持多分支管道、参数化构建、Docker集成

pipeline {
    agent {
        docker {
            image 'python:3.11'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    parameters {
        choice(
            name: 'PYTHON_VERSION',
            choices: ['3.9', '3.10', '3.11'],
            description: 'Select Python version'
        )
        choice(
            name: 'DEPLOY_ENV',
            choices: ['dev', 'staging', 'production'],
            description: 'Select deployment environment'
        )
        booleanParam(
            name: 'RUN_SECURITY_SCANS',
            defaultValue: true,
            description: 'Run security scans'
        )
        booleanParam(
            name: 'BUILD_DOCKER_IMAGE',
            defaultValue: false,
            description: 'Build Docker image'
        )
        string(
            name: 'TAGS',
            defaultValue: '',
            description: 'Pytest tags to run (optional)'
        )
    }

    environment {
        // 环境变量配置
        PYTHON_VERSION = "${params.PYTHON_VERSION}"
        POETRY_VERSION = "1.7.1"
        PROJECT_NAME = "${JOB_BASE_NAME}"
        DOCKER_REGISTRY = "registry.example.com"
        DOCKER_IMAGE = "${DOCKER_REGISTRY}/${PROJECT_NAME}:${BUILD_TAG}"

        // 凭据ID (在Jenkins中配置)
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        SLACK_WEBHOOK_URL = credentials('slack-webhook-url')

        // 路径配置
        TEST_RESULTS_DIR = 'test-results'
        COVERAGE_REPORTS_DIR = 'coverage-reports'
        ARTIFACTS_DIR = 'artifacts'
    }

    options {
        // 管道选项
        timeout(time: 30, unit: 'MINUTES')
        retry(2)
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps()
        ansiColor('xterm')
    }

    triggers {
        // 触发器配置
        pollSCM('H/5 * * * *')  // 每5分钟检查一次SCM
        // cron('0 2 * * *')     // 每日凌晨2点运行 (可选)
    }

    stages {
        stage('Checkout') {
            steps {
                // 检出代码
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "${BRANCH_NAME}"]],
                    extensions: [
                        [
                            $class: 'CleanBeforeCheckout'
                        ],
                        [
                            $class: 'RelativeTargetDirectory',
                            relativeTargetDir: 'source'
                        ]
                    ],
                    userRemoteConfigs: [[url: "${GIT_URL}"]]
                ])

                dir('source') {
                    script {
                        echo "Checking out ${BRANCH_NAME} from ${GIT_URL}"
                        currentBuild.description = "Branch: ${BRANCH_NAME} | Commit: ${GIT_COMMIT.take(8)}"
                    }
                }
            }
        }

        stage('Setup Environment') {
            steps {
                dir('source') {
                    script {
                        echo "Setting up Python ${PYTHON_VERSION} environment..."

                        // 创建虚拟环境
                        sh '''
                            python -m venv venv
                            source venv/bin/activate
                            pip install --upgrade pip
                        '''

                        // 检测并安装依赖管理器
                        sh '''
                            source venv/bin/activate
                            if [ -f "pyproject.toml" ]; then
                                pip install poetry==${POETRY_VERSION}
                                poetry install --no-root --no-interaction
                            elif [ -f "requirements.txt" ]; then
                                pip install -r requirements.txt
                            elif [ -f "setup.py" ]; then
                                pip install -e .
                            fi
                        '''
                    }
                }
            }
        }

        stage('Code Quality') {
            steps {
                dir('source') {
                    script {
                        echo "Running code quality checks..."

                        sh '''
                            source venv/bin/activate
                            # 代码格式化检查
                            pip install black flake8 isort mypy bandit

                            echo "=== Running Black (code formatting) ==="
                            black --check --diff . || true

                            echo "=== Running Flake8 (code style) ==="
                            flake8 . || true

                            echo "=== Running isort (import sorting) ==="
                            isort --check-only --diff . || true

                            echo "=== Running mypy (type checking) ==="
                            mypy . || true

                            echo "=== Running bandit (security) ==="
                            bandit -r . -f json -o ${ARTIFACTS_DIR}/bandit-report.json || true
                        '''
                    }
                }
            }

            post {
                always {
                    // 保存代码质量报告
                    dir('source') {
                        junit allowEmptyResults: true, testResults: '**/test-results/*.xml'
                        archiveArtifacts artifacts: '${ARTIFACTS_DIR}/*.json', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('source') {
                    script {
                        echo "Running unit tests..."

                        sh '''
                            source venv/bin/activate
                            # 安装测试依赖
                            pip install pytest pytest-cov pytest-html pytest-xdist

                            # 创建测试结果目录
                            mkdir -p ${TEST_RESULTS_DIR} ${COVERAGE_REPORTS_DIR}

                            # 运行测试
                            if [ -n "${TAGS}" ]; then
                                pytest tests/ \
                                    -m "${TAGS}" \
                                    --cov=. \
                                    --cov-report=xml:${COVERAGE_REPORTS_DIR}/coverage.xml \
                                    --cov-report=html:${COVERAGE_REPORTS_DIR}/htmlcov \
                                    --junitxml=${TEST_RESULTS_DIR}/junit.xml \
                                    --html=${TEST_RESULTS_DIR}/report.html \
                                    -n auto \
                                    -v
                            else
                                pytest tests/ \
                                    --cov=. \
                                    --cov-report=xml:${COVERAGE_REPORTS_DIR}/coverage.xml \
                                    --cov-report=html:${COVERAGE_REPORTS_DIR}/htmlcov \
                                    --junitxml=${TEST_RESULTS_DIR}/junit.xml \
                                    --html=${TEST_RESULTS_DIR}/report.html \
                                    -n auto \
                                    -v
                            fi
                        '''
                    }
                }
            }

            post {
                always {
                    // 保存测试结果和覆盖率报告
                    dir('source') {
                        junit testResults: '${TEST_RESULTS_DIR}/*.xml'
                        publishHTML([
                            allowMissing: false,
                            alwaysLinkToLastBuild: false,
                            keepAll: true,
                            reportDir: '${TEST_RESULTS_DIR}',
                            reportFiles: 'report.html',
                            reportName: 'Test Report'
                        ])
                        publishHTML([
                            allowMissing: false,
                            alwaysLinkToLastBuild: false,
                            keepAll: true,
                            reportDir: '${COVERAGE_REPORTS_DIR}/htmlcov',
                            reportFiles: 'index.html',
                            reportName: 'Coverage Report'
                        ])
                    }
                }
            }
        }

        stage('Integration Tests') {
            when {
                expression { params.DEPLOY_ENV != 'dev' }
            }
            steps {
                dir('source') {
                    script {
                        echo "Running integration tests..."

                        // 这里可以添加集成测试逻辑
                        sh '''
                            source venv/bin/activate
                            echo "Integration tests would run here..."
                            # 示例: pytest integration_tests/ -v
                        '''
                    }
                }
            }
        }

        stage('Security Scans') {
            when {
                expression { params.RUN_SECURITY_SCANS == true }
            }
            steps {
                dir('source') {
                    script {
                        echo "Running security scans..."

                        sh '''
                            source venv/bin/activate
                            # 依赖安全扫描
                            pip install safety trivy

                            echo "=== Running safety (dependency security) ==="
                            safety check --json > ${ARTIFACTS_DIR}/safety-report.json || true

                            # 容器安全扫描 (如果有Dockerfile)
                            if [ -f "Dockerfile" ] && [ "${BUILD_DOCKER_IMAGE}" = "true" ]; then
                                echo "=== Running trivy (container security) ==="
                                trivy image --format json --output ${ARTIFACTS_DIR}/trivy-report.json ${DOCKER_IMAGE} || true
                            fi
                        '''
                    }
                }
            }
        }

        stage('Build') {
            steps {
                dir('source') {
                    script {
                        echo "Building package..."

                        sh '''
                            source venv/bin/activate
                            pip install build twine

                            # 清理旧的构建文件
                            rm -rf dist/ build/

                            # 构建Python包
                            python -m build

                            # 验证包
                            python -m twine check dist/*
                        '''
                    }
                }
            }

            post {
                success {
                    // 保存构建产物
                    dir('source') {
                        archiveArtifacts artifacts: 'dist/**/*', fingerprint: true
                    }
                }
            }
        }

        stage('Build Docker Image') {
            when {
                expression { params.BUILD_DOCKER_IMAGE == true }
            }
            steps {
                script {
                    echo "Building Docker image..."

                    dir('source') {
                        // 构建Docker镜像
                        docker.withRegistry("https://${DOCKER_REGISTRY}", 'docker-registry-credentials') {
                            def customImage = docker.build("${DOCKER_IMAGE}", ".")

                            // 推送镜像
                            customImage.push()
                            customImage.push('latest')
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                expression {
                    // 只有在特定条件下才部署
                    params.DEPLOY_ENV != 'dev' &&
                    currentBuild.resultIsBetterOrEqualTo('SUCCESS')
                }
            }
            steps {
                script {
                    echo "Deploying to ${params.DEPLOY_ENV} environment..."

                    dir('source') {
                        // 根据环境选择部署脚本
                        switch(params.DEPLOY_ENV) {
                            case 'staging':
                                sh '''
                                    echo "Deploying to staging environment..."
                                    # 这里添加staging环境部署命令
                                    # 例如: kubectl apply -f k8s/staging/
                                '''
                                break
                            case 'production':
                                sh '''
                                    echo "Deploying to production environment..."
                                    # 这里添加production环境部署命令
                                    # 例如: kubectl apply -f k8s/production/
                                '''
                                break
                        }
                    }
                }
            }
        }
    }

    post {
        // 构建后处理
        always {
            script {
                echo "Pipeline completed with status: ${currentBuild.currentResult}"

                // 清理工作区
                cleanWs()
            }
        }

        success {
            script {
                echo "Pipeline succeeded!"

                // 发送成功通知
                slackSend(
                    channel: '#builds',
                    color: 'good',
                    message: "✅ Build #${BUILD_NUMBER} succeeded for ${PROJECT_NAME} (${BRANCH_NAME})"
                )
            }
        }

        failure {
            script {
                echo "Pipeline failed!"

                // 发送失败通知
                slackSend(
                    channel: '#builds',
                    color: 'danger',
                    message: "❌ Build #${BUILD_NUMBER} failed for ${PROJECT_NAME} (${BRANCH_NAME})"
                )
            }
        }

        unstable {
            script {
                echo "Pipeline is unstable!"

                // 发送不稳定通知
                slackSend(
                    channel: '#builds',
                    color: 'warning',
                    message: "⚠️ Build #${BUILD_NUMBER} is unstable for ${PROJECT_NAME} (${BRANCH_NAME})"
                )
            }
        }

        aborted {
            script {
                echo "Pipeline was aborted!"
            }
        }
    }
}