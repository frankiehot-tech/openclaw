// Jenkins Pipeline for Docker Projects
// 自动构建、测试和推送Docker镜像到容器注册表

pipeline {
    agent {
        docker {
            image 'docker:24'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    parameters {
        choice(
            name: 'DOCKERFILE_PATH',
            choices: ['Dockerfile', 'docker/Dockerfile', 'build/Dockerfile'],
            description: 'Select Dockerfile path'
        )
        choice(
            name: 'DEPLOY_ENV',
            choices: ['none', 'staging', 'production'],
            description: 'Select deployment environment'
        )
        booleanParam(
            name: 'RUN_SECURITY_SCANS',
            defaultValue: true,
            description: 'Run security scans (Trivy)'
        )
        booleanParam(
            name: 'MULTI_ARCH_BUILD',
            defaultValue: false,
            description: 'Build multi-architecture images'
        )
        booleanParam(
            name: 'GENERATE_SBOM',
            defaultValue: true,
            description: 'Generate Software Bill of Materials (SBOM)'
        )
        string(
            name: 'IMAGE_TAGS',
            defaultValue: '${BUILD_TAG},latest',
            description: 'Image tags (comma-separated)'
        )
        string(
            name: 'BUILD_ARGS',
            defaultValue: '',
            description: 'Docker build arguments (key=value, comma-separated)'
        )
    }

    environment {
        // 环境变量配置
        DOCKERFILE_PATH = "${params.DOCKERFILE_PATH}"
        PROJECT_NAME = "${JOB_BASE_NAME}"
        DOCKER_REGISTRY = "registry.example.com"

        // 镜像标签处理
        IMAGE_TAGS_LIST = "${params.IMAGE_TAGS}".split(',')
        PRIMARY_IMAGE_TAG = IMAGE_TAGS_LIST[0]
        DOCKER_IMAGE = "${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG}"

        // BuildKit配置
        DOCKER_BUILDKIT = "1"

        // 凭据ID (在Jenkins中配置)
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        SLACK_WEBHOOK_URL = credentials('slack-webhook-url')
        GITHUB_TOKEN = credentials('github-token')

        // 路径配置
        ARTIFACTS_DIR = 'artifacts'
        SCAN_RESULTS_DIR = 'scan-results'
    }

    options {
        // 管道选项
        timeout(time: 60, unit: 'MINUTES')
        retry(2)
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps()
        ansiColor('xterm')
    }

    triggers {
        // 触发器配置
        pollSCM('H/5 * * * *')  // 每5分钟检查一次SCM
        cron('0 2 * * 1')       // 每周一凌晨2点运行 (安全扫描)
    }

    stages {
        stage('Checkout') {
            steps {
                // 检出代码
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "${BRANCH_NAME}"]],
                    extensions: [
                        [
                            $class: 'CleanBeforeCheckout'
                        ],
                        [
                            $class: 'RelativeTargetDirectory',
                            relativeTargetDir: 'source'
                        ]
                    ],
                    userRemoteConfigs: [[url: "${GIT_URL}"]]
                ])

                dir('source') {
                    script {
                        echo "Checking out ${BRANCH_NAME} from ${GIT_URL}"
                        currentBuild.description = "Branch: ${BRANCH_NAME} | Commit: ${GIT_COMMIT.take(8)} | Dockerfile: ${DOCKERFILE_PATH}"
                    }
                }
            }
        }

        stage('Dockerfile Lint') {
            steps {
                dir('source') {
                    script {
                        echo "Linting Dockerfile..."

                        // 检查Dockerfile是否存在
                        if (!fileExists(DOCKERFILE_PATH)) {
                            error "Dockerfile not found at path: ${DOCKERFILE_PATH}"
                        }

                        // 安装hadolint
                        sh '''
                            apk add --no-cache curl
                            curl -sSL https://github.com/hadolint/hadolint/releases/download/v2.12.0/hadolint-Linux-x86_64 -o /usr/local/bin/hadolint
                            chmod +x /usr/local/bin/hadolint
                        '''

                        // 运行hadolint检查
                        sh """
                            hadolint ${DOCKERFILE_PATH} || echo "hadolint found issues, check Dockerfile syntax"
                        """

                        // 多阶段构建检查
                        sh """
                            if ! grep -q "FROM.*AS.*builder\\|FROM.*as.*builder" ${DOCKERFILE_PATH}; then
                                echo "⚠️  Consider using multi-stage build to optimize image size"
                            fi
                        """

                        // 安全检查
                        sh """
                            echo "Dockerfile security checks:"
                            echo "1. Checking for non-root user..."
                            if ! grep -q "USER.*1000\\|USER.*65532" ${DOCKERFILE_PATH}; then
                                echo "❌ Consider adding non-root user"
                            else
                                echo "✅ Non-root user found"
                            fi

                            echo "2. Checking for package cache updates..."
                            if ! grep -q "apt-get update && apt-get upgrade\\|apk update && apk upgrade" ${DOCKERFILE_PATH}; then
                                echo "⚠️  Consider updating package cache for security updates"
                            fi

                            echo "3. Checking for package cache cleanup..."
                            if ! grep -q "rm -rf /var/lib/apt/lists/\\*\\|rm -rf /var/cache/apk/\\*" ${DOCKERFILE_PATH}; then
                                echo "⚠️  Consider cleaning package cache to reduce image size"
                            fi
                        """
                    }
                }
            }
        }

        stage('Setup Buildx') {
            steps {
                dir('source') {
                    script {
                        echo "Setting up Docker Buildx..."

                        // 安装Buildx
                        sh '''
                            docker buildx version || docker buildx install
                            docker buildx create --name multiarch-builder --use || true
                            docker buildx inspect --bootstrap
                        '''

                        // 如果启用多架构构建，设置平台
                        if (params.MULTI_ARCH_BUILD) {
                            sh '''
                                docker buildx create --name multiarch-builder --platform linux/amd64,linux/arm64 --use || true
                                docker buildx inspect --bootstrap
                            '''
                        }
                    }
                }
            }
        }

        stage('Container Test') {
            steps {
                dir('source') {
                    script {
                        echo "Testing container..."

                        // 构建测试镜像
                        def buildArgs = parseBuildArgs(params.BUILD_ARGS)
                        def buildArgsString = buildArgs.collect { "-build-arg ${it.key}=${it.value}" }.join(' ')

                        sh """
                            docker build -t ${DOCKER_IMAGE}:test ${buildArgsString} -f ${DOCKERFILE_PATH} .
                        """

                        // 运行容器健康检查
                        sh '''
                            docker run -d --name test-container -p 8080:8080 ${DOCKER_IMAGE}:test
                            sleep 10  # 等待容器启动
                        '''

                        // 检查容器是否运行
                        sh '''
                            if docker ps | grep -q test-container; then
                                echo "✅ Container is running"
                            else
                                echo "❌ Container failed to start"
                                docker logs test-container
                                exit 1
                            fi
                        '''

                        // 健康检查
                        sh '''
                            if curl -s --retry 3 --retry-delay 5 http://localhost:8080/health > /dev/null; then
                                echo "✅ Health check passed"
                            else
                                echo "❌ Health check failed"
                                docker logs test-container
                                exit 1
                            fi
                        '''

                        // 清理测试容器
                        sh '''
                            docker stop test-container || true
                            docker rm test-container || true
                        '''
                    }
                }
            }
        }

        stage('Security Scan') {
            when {
                expression { params.RUN_SECURITY_SCANS == true }
            }
            steps {
                dir('source') {
                    script {
                        echo "Running security scans..."

                        // 安装Trivy
                        sh '''
                            apk add --no-cache curl
                            curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
                        '''

                        // 运行Trivy扫描
                        sh """
                            mkdir -p ${SCAN_RESULTS_DIR}
                            trivy image --format sarif --output ${SCAN_RESULTS_DIR}/trivy-image.sarif ${DOCKER_IMAGE}:test --severity CRITICAL,HIGH
                            trivy config --format sarif --output ${SCAN_RESULTS_DIR}/trivy-config.sarif . --severity CRITICAL,HIGH
                        """

                        // 检查是否有严重漏洞
                        sh '''
                            if trivy image --severity CRITICAL ${DOCKER_IMAGE}:test --exit-code 1; then
                                echo "❌ Critical vulnerabilities found"
                            else
                                echo "✅ No critical vulnerabilities found"
                            fi
                        '''
                    }
                }
            }

            post {
                always {
                    dir('source') {
                        archiveArtifacts artifacts: "${SCAN_RESULTS_DIR}/**", allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Build and Push') {
            steps {
                dir('source') {
                    script {
                        echo "Building and pushing Docker image..."

                        // 登录到Docker注册表
                        withCredentials([usernamePassword(
                            credentialsId: 'docker-registry-creds',
                            usernameVariable: 'DOCKER_USERNAME',
                            passwordVariable: 'DOCKER_PASSWORD'
                        )]) {
                            sh """
                                docker login ${DOCKER_REGISTRY} -u ${DOCKER_USERNAME} -p ${DOCKER_PASSWORD}
                            '''
                        }

                        // 构建参数处理
                        def buildArgs = parseBuildArgs(params.BUILD_ARGS)
                        def buildArgsString = buildArgs.collect { "--build-arg ${it.key}=${it.value}" }.join(' ')

                        // 标签处理
                        def tagsString = IMAGE_TAGS_LIST.collect { "${DOCKER_REGISTRY}/${PROJECT_NAME}:${it}" }.join(',')

                        if (params.MULTI_ARCH_BUILD) {
                            // 多架构构建
                            sh """
                                docker buildx build \
                                    --platform linux/amd64,linux/arm64 \
                                    ${buildArgsString} \
                                    -f ${DOCKERFILE_PATH} \
                                    --tag ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG} \
                                    --push \
                                    .
                            """

                            // 为其他标签创建manifest
                            if (IMAGE_TAGS_LIST.size() > 1) {
                                for (int i = 1; i < IMAGE_TAGS_LIST.size(); i++) {
                                    def tag = IMAGE_TAGS_LIST[i]
                                    sh """
                                        docker buildx imagetools create \
                                            -t ${DOCKER_REGISTRY}/${PROJECT_NAME}:${tag} \
                                            ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG}
                                    """
                                }
                            }
                        } else {
                            // 单架构构建
                            sh """
                                docker build ${buildArgsString} \
                                    -f ${DOCKERFILE_PATH} \
                                    -t ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG} \
                                    .
                            """

                            // 推送主标签
                            sh """
                                docker push ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG}
                            """

                            // 为其他标签创建标签并推送
                            if (IMAGE_TAGS_LIST.size() > 1) {
                                for (int i = 1; i < IMAGE_TAGS_LIST.size(); i++) {
                                    def tag = IMAGE_TAGS_LIST[i]
                                    sh """
                                        docker tag ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG} ${DOCKER_REGISTRY}/${PROJECT_NAME}:${tag}
                                        docker push ${DOCKER_REGISTRY}/${PROJECT_NAME}:${tag}
                                    """
                                }
                            }
                        }
                    }
                }
            }
        }

        stage('Generate SBOM') {
            when {
                expression { params.GENERATE_SBOM == true }
            }
            steps {
                dir('source') {
                    script {
                        echo "Generating Software Bill of Materials (SBOM)..."

                        // 使用Syft生成SBOM
                        sh '''
                            docker run --rm \
                                -v /var/run/docker.sock:/var/run/docker.sock \
                                anchore/syft:latest \
                                ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG} \
                                -o spdx-json > sbom.spdx.json
                        '''

                        // 使用Trivy生成漏洞报告
                        sh '''
                            trivy image --format cyclonedx ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG} > sbom.cyclonedx.json
                        '''
                    }
                }
            }

            post {
                always {
                    dir('source') {
                        archiveArtifacts artifacts: 'sbom.*.json', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                expression { params.DEPLOY_ENV == 'staging' }
            }
            steps {
                dir('source') {
                    script {
                        echo "Deploying to staging environment..."

                        // 更新Kubernetes部署文件中的镜像版本
                        if (fileExists('deployment/kubernetes/staging/deployment.yaml')) {
                            withCredentials([file(
                                credentialsId: 'kubeconfig-staging',
                                variable: 'KUBECONFIG_FILE'
                            )]) {
                                sh '''
                                    cp ${KUBECONFIG_FILE} kubeconfig.yaml
                                    export KUBECONFIG=kubeconfig.yaml

                                    # 更新镜像版本
                                    sed -i "s|image:.*|image: ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG}|g" deployment/kubernetes/staging/deployment.yaml

                                    # 部署到Kubernetes
                                    kubectl apply -f deployment/kubernetes/staging/
                                    kubectl rollout status deployment/app -n staging --timeout=300s
                                '''
                            }
                        } else {
                            echo "No staging deployment configuration found"
                        }
                    }
                }
            }
        }

        stage('Deploy to Production') {
            when {
                expression { params.DEPLOY_ENV == 'production' }
            }
            steps {
                dir('source') {
                    script {
                        echo "Deploying to production environment..."

                        // 蓝绿部署
                        if (fileExists('deployment/kubernetes/production/deployment.yaml')) {
                            withCredentials([file(
                                credentialsId: 'kubeconfig-production',
                                variable: 'KUBECONFIG_FILE'
                            )]) {
                                sh '''
                                    cp ${KUBECONFIG_FILE} kubeconfig.yaml
                                    export KUBECONFIG=kubeconfig.yaml

                                    # 创建新部署 (绿色环境)
                                    sed "s|image:.*|image: ${DOCKER_REGISTRY}/${PROJECT_NAME}:${PRIMARY_IMAGE_TAG}|g" deployment/kubernetes/production/deployment.yaml > deployment-green.yaml
                                    sed -i 's/name: app-deployment/name: app-deployment-green/g' deployment-green.yaml

                                    # 应用新部署
                                    kubectl apply -f deployment-green.yaml
                                    kubectl rollout status deployment/app-deployment-green -n production --timeout=300s

                                    # 切换流量
                                    kubectl patch service app-service -n production -p '{"spec":{"selector":{"app":"app","version":"green"}}}'
                                    sleep 30  # 等待流量切换

                                    # 清理旧部署
                                    kubectl delete deployment app-deployment -n production || true
                                '''
                            }
                        } else {
                            echo "No production deployment configuration found"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Pipeline completed with status: ${currentBuild.currentResult}"

                // 发送通知到Slack
                if (currentBuild.currentResult == 'SUCCESS') {
                    slackSend(
                        color: 'good',
                        message: "✅ Docker pipeline ${JOB_NAME} #${BUILD_NUMBER} succeeded\nImage: ${DOCKER_IMAGE}"
                    )
                } else if (currentBuild.currentResult == 'FAILURE') {
                    slackSend(
                        color: 'danger',
                        message: "❌ Docker pipeline ${JOB_NAME} #${BUILD_NUMBER} failed"
                    )
                }
            }
        }

        cleanup {
            dir('source') {
                // 清理临时文件
                sh '''
                    rm -rf ${SCAN_RESULTS_DIR}/
                    rm -f kubeconfig.yaml deployment-green.yaml
                    docker rmi ${DOCKER_IMAGE}:test || true
                '''
            }
        }
    }
}

// 辅助函数
def parseBuildArgs(buildArgsString) {
    def buildArgs = [:]
    if (buildArgsString && buildArgsString.trim()) {
        buildArgsString.split(',').each { arg ->
            def parts = arg.split('=', 2)
            if (parts.size() == 2) {
                buildArgs[parts[0].trim()] = parts[1].trim()
            }
        }
    }
    return buildArgs
}