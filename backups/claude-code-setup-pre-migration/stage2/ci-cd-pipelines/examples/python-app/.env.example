# Python Flask应用环境变量配置
# 将此文件复制为 .env 并根据需要修改配置

# ============================================
# 应用配置
# ============================================

# Flask环境 (development, production, testing)
FLASK_ENV=development
FLASK_DEBUG=1

# 应用密钥 (生产环境必须修改!)
SECRET_KEY=dev-secret-key-change-in-production

# 应用监听地址和端口
HOST=0.0.0.0
PORT=5000

# CORS配置
CORS_ORIGINS=*

# ============================================
# 数据库配置
# ============================================

# PostgreSQL数据库连接
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb

# SQLAlchemy配置
SQLALCHEMY_DATABASE_URI=${DATABASE_URL}
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_POOL_RECYCLE=300
SQLALCHEMY_MAX_OVERFLOW=10

# ============================================
# Redis配置
# ============================================

# Redis连接
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 缓存配置
CACHE_TTL=300
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# JWT配置
# ============================================

# JWT令牌配置
JWT_SECRET_KEY=${SECRET_KEY}
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# ============================================
# 监控配置
# ============================================

# Prometheus指标
ENABLE_METRICS=true
METRICS_PORT=5001

# 健康检查配置
HEALTH_CHECK_TIMEOUT=5
READINESS_CHECK_TIMEOUT=10

# ============================================
# 安全配置
# ============================================

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# API速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_AUTH=50/hour
RATE_LIMIT_API=200/hour

# ============================================
# 测试配置
# ============================================

# 测试数据库
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb_test
TEST_REDIS_URL=redis://localhost:6379/1

# 测试模式
TESTING=True
SQLALCHEMY_DATABASE_URI_TEST=${TEST_DATABASE_URL}

# ============================================
# 外部服务配置
# ============================================

# SMTP邮件服务
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# AWS S3存储
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket

# ============================================
# 开发工具配置
# ============================================

# 代码检查工具
BLACK_LINE_LENGTH=88
FLAKE8_MAX_LINE_LENGTH=100
MYPY_STRICT=true

# ============================================
# 部署配置
# ============================================

# Docker镜像标签
DOCKER_REGISTRY=your-registry.com
DOCKER_IMAGE_NAME=python-app
DOCKER_IMAGE_TAG=latest

# Kubernetes命名空间
K8S_NAMESPACE=default
K8S_DEPLOYMENT_NAME=python-app
K8S_SERVICE_NAME=python-app-service

# ============================================
# 重要提示
# ============================================
# 1. 生产环境必须修改所有安全相关配置
# 2. 敏感信息应使用密钥管理服务
# 3. 不同环境使用不同的配置文件
# 4. 定期更新密码和密钥