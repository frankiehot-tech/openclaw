#!/bin/bash
# Git pre-commit hook: 阻止包含 Claude Code 指纹的代码提交

set -euo pipefail

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Claude Code 指纹模式
PATTERNS=(
    "Generated by Claude Code"
    "Generated with Claude Code"
    "Created by Claude Code"
    "Created with Claude Code"
    "Claude Code generated"
    "AI-generated by Claude"
    "<!-- claude:"
    "<!-- claude-code:"
    "// claude:"
    "# claude:"
    "/* claude:"
    "claude-version:"
    "claude-model:"
    "claude-session:"
    "anthropic-session:"
    "# Assistant: Claude"
    "# Model: Claude"
    "# Tool: Claude Code"
)

# 获取待提交的文件列表
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND=0

for file in $STAGED_FILES; do
    # 只检查文本文件
    if [ -f "$file" ] && file "$file" | grep -q text; then
        for pattern in "${PATTERNS[@]}"; do
            if grep -q "$pattern" "$file" 2>/dev/null; then
                echo -e "${RED}❌ 提交被阻止: 发现 Claude Code 指纹${NC}"
                echo -e "${YELLOW}文件: $file${NC}"
                echo -e "${YELLOW}匹配: $pattern${NC}"
                echo ""
                echo -e "${YELLOW}建议:${NC}"
                echo "  1. 运行指纹清理工具: ./clean-claude-fingerprints.sh"
                echo "  2. 或手动删除指纹后重新提交"
                echo ""
                FOUND=1
            fi
        done
    fi
done

if [ $FOUND -eq 1 ]; then
    exit 1
fi

echo -e "${GREEN}✅ 未检测到 Claude Code 指纹，允许提交${NC}"
exit 0
