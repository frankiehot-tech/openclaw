# Helper function to safely emit events
def emit_event(
    event_type, scope, payload, metadata=None, evidence=None, hook_point=None
):
    """Emit an event via the bus if available, otherwise no-op."""
    try:
        if EVENT_BUS_AVAILABLE and emit is not None:
            return emit(event_type, scope, payload, metadata, evidence, hook_point)
    except Exception:
        pass
    return None


def record_performance_metric(dimension, value, labels=None, metadata=None):
    """Record a performance metric if metrics collection is available."""
    try:
        if PERFORMANCE_METRICS_AVAILABLE:
            from agent.core.performance_metrics import MetricDimension, MetricType

            # Convert string dimension to enum if needed
            if isinstance(dimension, str):
                dimension = MetricDimension[dimension]
            get_global_collector().record(
                dimension=dimension,
                value=value,
                metric_type=MetricType.GAUGE,
                labels=labels or {},
                metadata=metadata or {},
            )
    except Exception:
        pass  # Silently fail if metrics collection fails


# Register a simple logging hook if event bus is available
if EVENT_BUS_AVAILABLE:
    try:
        bus = get_bus()
        # Simple hook that logs events to a file for verification
        log_path = RUNTIME_ROOT / ".openclaw" / "event_bus_log.jsonl"
        log_path.parent.mkdir(parents=True, exist_ok=True)
        import json

        def log_hook(event):
            try:
                entry = {
                    "timestamp": event.timestamp,
                    "event_type": event.event_type,
                    "scope": event.scope,
                    "hook_point": event.metadata.get("hook_point"),
                }
                with open(log_path, "a", encoding="utf-8") as f:
                    f.write(json.dumps(entry, ensure_ascii=False) + "\n")
            except Exception:
                pass
            return None  # don't modify event

        # Register for all hook points
        bus.register_hook(HookPoint.PRE_TOOL, log_hook)
        bus.register_hook(HookPoint.POST_TOOL, log_hook)
        bus.register_hook(HookPoint.TASK_START, log_hook)
        bus.register_hook(HookPoint.TASK_FINISH, log_hook)
        bus.register_hook(HookPoint.ARTIFACT_WRITTEN, log_hook)
    except Exception:
        pass

