# MAREF通知系统环境变量配置
# 此文件包含敏感凭据，不要提交到版本控制系统

# ==================== 企业微信配置 ====================

# Webhook方式（优先级高于应用API）
WECOM_WEBHOOK_URL=http://127.0.0.1:18789/wecom/webhook
WECOM_WEBHOOK_TOKEN=6XeXrzS9AbblMaNY3ht8jv

# 应用API方式（如需使用IP白名单）
WECOM_CORPID=ww02c09b741b716c32
WECOM_AGENTID=1000002
WECOM_SECRET=REDACTED_WECOM_SECRET

# ==================== QQ邮箱配置 ====================

# QQ邮箱SMTP配置（需要16位授权码）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=athenabot@qq.com
SMTP_PASSWORD=REDACTED_SMTP_PASSWORD
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# 邮件接收者（逗号分隔）
EMAIL_RECEIVERS=athenabot@qq.com

# ==================== Slack配置 ====================

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/PATH

# ==================== Athena集成 ====================

ATHENA_API_URL=http://localhost:8000/api/notifications
ATHENA_BOT_ID=aib_cwIn1QD-bZw7tdx0KQooLb-A1S3gLjo
ATHENA_BOT_SECRET=REDACTED_ATHENA_BOT_SECRET

# ==================== 安全配置 ====================

# 通知频率限制（每分钟最多发送通知数）
NOTIFICATION_RATE_LIMIT=10

# 重试配置
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=5000

# ==================== 日志配置 ====================

# 日志文件路径
NOTIFICATION_LOG_PATH=/Volumes/1TB-M2/openclaw/scripts/clawra/logs/maref_notifications.log

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 功能开关 ====================

# 启用/禁用特定渠道
ENABLE_WECOM=true
ENABLE_EMAIL=true
ENABLE_SLACK=false
ENABLE_CONSOLE=true
ENABLE_FILE_LOG=true
ENABLE_ATHENA_INTEGRATION=true

# 注意：
# 1. 配置优先级：环境变量 > 配置文件 > 默认值
# 2. 密码等敏感信息务必使用环境变量
# 3. 定期轮换敏感凭据（建议90天）
# 4. 监控通知发送失败率