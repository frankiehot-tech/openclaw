# ============================================
# OpenClaw / OpenHuman 环境变量模板
# 复制为 .env 并填入真实值
# ============================================

# AI API Keys
DASHSCOPE_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 邮件通知 (可选)
QQ_EMAIL_AUTH_CODE=your-auth-code
OPENCLAW_SMTP_SERVER=smtp.gmail.com
OPENCLAW_SMTP_PORT=587
OPENCLAW_EMAIL_USERNAME=your-email@gmail.com
OPENCLAW_EMAIL_PASSWORD=your-app-password

# Slack 通知 (可选)
OPENCLAW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Athena 运行配置
ATHENA_AI_PLAN_MAX_BUILD_WORKERS=2
ATHENA_AI_PLAN_MIN_FREE_MEMORY_PERCENT=10
ATHENA_MAX_CONCURRENT_TASKS=3
ATHENA_TASK_PRIORITY=high
ATHENA_TASK_MEMORY_LIMIT_MB=2048
ATHENA_SYSTEM_RESERVE_MEMORY_PERCENT=20
ATHENA_PERFORMANCE_MONITORING=true
ATHENA_MONITOR_INTERVAL_SECONDS=30
ATHENA_VERBOSE_LOGGING=true
