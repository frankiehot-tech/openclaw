// Jenkins Pipeline for Node.js Projects
// 支持多分支管道、参数化构建、Docker集成

pipeline {
    agent {
        docker {
            image 'node:18-alpine'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    parameters {
        choice(
            name: 'NODE_VERSION',
            choices: ['16', '18', '20'],
            description: 'Select Node.js version'
        )
        choice(
            name: 'DEPLOY_ENV',
            choices: ['dev', 'staging', 'production'],
            description: 'Select deployment environment'
        )
        booleanParam(
            name: 'RUN_SECURITY_SCANS',
            defaultValue: true,
            description: 'Run security scans'
        )
        booleanParam(
            name: 'BUILD_DOCKER_IMAGE',
            defaultValue: false,
            description: 'Build Docker image'
        )
        choice(
            name: 'PACKAGE_MANAGER',
            choices: ['npm', 'yarn', 'pnpm'],
            description: 'Select package manager'
        )
        booleanParam(
            name: 'RUN_E2E_TESTS',
            defaultValue: false,
            description: 'Run E2E tests (requires Docker)'
        )
    }

    environment {
        // 环境变量配置
        NODE_VERSION = "${params.NODE_VERSION}"
        PACKAGE_MANAGER = "${params.PACKAGE_MANAGER}"
        PROJECT_NAME = "${JOB_BASE_NAME}"
        DOCKER_REGISTRY = "registry.example.com"
        DOCKER_IMAGE = "${DOCKER_REGISTRY}/${PROJECT_NAME}:${BUILD_TAG}"

        // 包管理器特定配置
        NPM_CONFIG_CACHE = "${WORKSPACE}/.npm"
        YARN_CACHE_FOLDER = "${WORKSPACE}/.yarn-cache"

        // 凭据ID (在Jenkins中配置)
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        SLACK_WEBHOOK_URL = credentials('slack-webhook-url')
        SNYK_TOKEN = credentials('snyk-token')

        // 路径配置
        TEST_RESULTS_DIR = 'test-results'
        COVERAGE_REPORTS_DIR = 'coverage-reports'
        ARTIFACTS_DIR = 'artifacts'
    }

    options {
        // 管道选项
        timeout(time: 30, unit: 'MINUTES')
        retry(2)
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps()
        ansiColor('xterm')
    }

    triggers {
        // 触发器配置
        pollSCM('H/5 * * * *')  // 每5分钟检查一次SCM
        // cron('0 2 * * *')     // 每日凌晨2点运行 (可选)
    }

    stages {
        stage('Checkout') {
            steps {
                // 检出代码
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "${BRANCH_NAME}"]],
                    extensions: [
                        [
                            $class: 'CleanBeforeCheckout'
                        ],
                        [
                            $class: 'RelativeTargetDirectory',
                            relativeTargetDir: 'source'
                        ]
                    ],
                    userRemoteConfigs: [[url: "${GIT_URL}"]]
                ])

                dir('source') {
                    script {
                        echo "Checking out ${BRANCH_NAME} from ${GIT_URL}"
                        currentBuild.description = "Branch: ${BRANCH_NAME} | Commit: ${GIT_COMMIT.take(8)} | Node: ${NODE_VERSION}"
                    }
                }
            }
        }

        stage('Setup') {
            steps {
                dir('source') {
                    script {
                        echo "Setting up Node.js ${NODE_VERSION} with ${PACKAGE_MANAGER}"

                        // 安装包管理器
                        if (PACKAGE_MANAGER == 'yarn') {
                            sh 'npm install -g yarn'
                        } else if (PACKAGE_MANAGER == 'pnpm') {
                            sh 'npm install -g pnpm'
                        }

                        // 检查包管理器版本
                        sh "${PACKAGE_MANAGER} --version"
                    }
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('source') {
                    script {
                        echo "Installing dependencies with ${PACKAGE_MANAGER}"

                        // 根据包管理器安装依赖
                        switch(PACKAGE_MANAGER) {
                            case 'npm':
                                if (fileExists('package-lock.json')) {
                                    sh 'npm ci --cache ${NPM_CONFIG_CACHE} --prefer-offline'
                                } else {
                                    sh 'npm install --cache ${NPM_CONFIG_CACHE} --prefer-offline'
                                }
                                break
                            case 'yarn':
                                if (fileExists('yarn.lock')) {
                                    sh 'yarn install --frozen-lockfile --cache-folder ${YARN_CACHE_FOLDER}'
                                } else {
                                    sh 'yarn install --cache-folder ${YARN_CACHE_FOLDER}'
                                }
                                break
                            case 'pnpm':
                                if (fileExists('pnpm-lock.yaml')) {
                                    sh 'pnpm install --frozen-lockfile'
                                } else {
                                    sh 'pnpm install'
                                }
                                break
                            default:
                                error "Unsupported package manager: ${PACKAGE_MANAGER}"
                        }
                    }
                }
            }
        }

        stage('Lint and Code Quality') {
            steps {
                dir('source') {
                    script {
                        echo "Running code quality checks..."

                        // ESLint检查
                        if (fileExists('node_modules/.bin/eslint')) {
                            sh '''
                                npx eslint . --ext .js,.jsx,.ts,.tsx --format json --output-file eslint-report.json || true
                            '''
                        } else {
                            echo "ESLint not installed, skipping"
                        }

                        // TypeScript类型检查
                        if (fileExists('tsconfig.json') && fileExists('node_modules/.bin/tsc')) {
                            sh 'npx tsc --noEmit || true'
                        }

                        // Prettier格式化检查
                        if (fileExists('node_modules/.bin/prettier')) {
                            sh 'npx prettier --check . || true'
                        }
                    }
                }
            }

            post {
                always {
                    dir('source') {
                        archiveArtifacts artifacts: 'eslint-report.json', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Unit Tests') {
            parallel {
                stage('Test Node 16') {
                    when {
                        expression { params.NODE_VERSION == '16' }
                    }
                    steps {
                        dir('source') {
                            script {
                                echo "Running tests with Node.js 16..."
                                runNodeJSTests()
                            }
                        }
                    }
                }

                stage('Test Node 18') {
                    when {
                        expression { params.NODE_VERSION == '18' }
                    }
                    steps {
                        dir('source') {
                            script {
                                echo "Running tests with Node.js 18..."
                                runNodeJSTests()
                            }
                        }
                    }
                }

                stage('Test Node 20') {
                    when {
                        expression { params.NODE_VERSION == '20' }
                    }
                    steps {
                        dir('source') {
                            script {
                                echo "Running tests with Node.js 20..."
                                runNodeJSTests()
                            }
                        }
                    }
                }
            }

            post {
                always {
                    dir('source') {
                        // 保存测试结果
                        junit allowEmptyResults: true, testResults: '${TEST_RESULTS_DIR}/*.xml'

                        // 保存覆盖率报告
                        publishHTML([
                            reportDir: 'coverage/lcov-report',
                            reportFiles: 'index.html',
                            reportName: 'Coverage Report'
                        ])
                    }
                }
            }
        }

        stage('E2E Tests') {
            when {
                expression { params.RUN_E2E_TESTS == true }
            }
            agent {
                docker {
                    image 'cypress/included:12.0.0'
                    args '-v /var/run/docker.sock:/var/run/docker.sock'
                }
            }
            steps {
                dir('source') {
                    script {
                        echo "Running E2E tests with Cypress..."

                        // 启动应用 (假设有启动脚本)
                        sh 'npm start &'
                        sh 'sleep 10'  // 等待应用启动

                        // 运行Cypress测试
                        sh 'npx cypress run --record false --browser chrome'
                    }
                }
            }

            post {
                always {
                    dir('source') {
                        archiveArtifacts artifacts: 'cypress/videos/*,cypress/screenshots/*', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Security Scan') {
            when {
                expression { params.RUN_SECURITY_SCANS == true }
            }
            steps {
                dir('source') {
                    script {
                        echo "Running security scans..."

                        // npm安全审计
                        sh 'npm audit --json > npm-audit-report.json || true'

                        // Retire.js依赖漏洞扫描
                        sh '''
                            npx retire --outputformat json --outputpath retirejs-report.json || true
                        '''

                        // Snyk安全扫描 (需要SNYK_TOKEN)
                        if (SNYK_TOKEN) {
                            sh '''
                                npx snyk test --json > snyk-report.json || true
                            '''
                        } else {
                            echo "SNYK_TOKEN not set, skipping Snyk scan"
                        }
                    }
                }
            }

            post {
                always {
                    dir('source') {
                        archiveArtifacts artifacts: 'npm-audit-report.json,retirejs-report.json,snyk-report.json', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Build') {
            steps {
                dir('source') {
                    script {
                        echo "Building application..."

                        // 检测构建脚本
                        if (fileExists('package.json')) {
                            def packageJson = readJSON file: 'package.json'
                            if (packageJson.scripts && packageJson.scripts.build) {
                                sh 'npm run build'
                            } else if (fileExists('webpack.config.js') || fileExists('vite.config.js')) {
                                sh '''
                                    npx webpack --mode production || npx vite build || echo "Build failed"
                                '''
                            } else {
                                echo "No build configuration found"
                            }
                        }
                    }
                }
            }

            post {
                success {
                    dir('source') {
                        archiveArtifacts artifacts: 'dist/**,build/**,public/**', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Build Docker Image') {
            when {
                expression { params.BUILD_DOCKER_IMAGE == true }
            }
            agent {
                docker {
                    image 'docker:24'
                    args '-v /var/run/docker.sock:/var/run/docker.sock'
                }
            }
            steps {
                dir('source') {
                    script {
                        echo "Building Docker image..."

                        // 登录到Docker注册表
                        withCredentials([usernamePassword(
                            credentialsId: 'docker-registry-creds',
                            usernameVariable: 'DOCKER_USERNAME',
                            passwordVariable: 'DOCKER_PASSWORD'
                        )]) {
                            sh '''
                                docker login ${DOCKER_REGISTRY} -u ${DOCKER_USERNAME} -p ${DOCKER_PASSWORD}
                            '''
                        }

                        // 构建并推送镜像
                        sh '''
                            docker build -t ${DOCKER_IMAGE} .
                            docker push ${DOCKER_IMAGE}
                        '''
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                expression { params.DEPLOY_ENV == 'staging' }
            }
            steps {
                dir('source') {
                    script {
                        echo "Deploying to staging environment..."

                        // 部署到Kubernetes示例
                        if (fileExists('deployment.yaml')) {
                            withCredentials([file(
                                credentialsId: 'kubeconfig-staging',
                                variable: 'KUBECONFIG_FILE'
                            )]) {
                                sh '''
                                    cp ${KUBECONFIG_FILE} kubeconfig.yaml
                                    export KUBECONFIG=kubeconfig.yaml
                                    kubectl apply -f deployment.yaml -n staging
                                    kubectl rollout status deployment/app -n staging --timeout=300s
                                '''
                            }
                        } else {
                            echo "No deployment configuration found"
                        }
                    }
                }
            }
        }

        stage('Deploy to Production') {
            when {
                expression { params.DEPLOY_ENV == 'production' }
            }
            steps {
                dir('source') {
                    script {
                        echo "Deploying to production environment..."

                        // 蓝绿部署示例
                        if (fileExists('deployment.yaml') && params.BUILD_DOCKER_IMAGE == true) {
                            withCredentials([file(
                                credentialsId: 'kubeconfig-production',
                                variable: 'KUBECONFIG_FILE'
                            )]) {
                                sh '''
                                    cp ${KUBECONFIG_FILE} kubeconfig.yaml
                                    export KUBECONFIG=kubeconfig.yaml

                                    # 创建新部署 (绿色环境)
                                    sed "s|image:.*|image: ${DOCKER_IMAGE}|g" deployment.yaml > deployment-green.yaml
                                    sed -i 's/name: app-deployment/name: app-deployment-green/g' deployment-green.yaml

                                    kubectl apply -f deployment-green.yaml -n production
                                    kubectl rollout status deployment/app-deployment-green -n production --timeout=300s

                                    # 切换服务流量
                                    kubectl patch service app-service -n production -p '{"spec":{"selector":{"app":"app","version":"green"}}}'
                                    sleep 30

                                    # 清理旧部署
                                    kubectl delete deployment app-deployment -n production || true
                                '''
                            }
                        } else {
                            echo "Docker image not built or no deployment configuration found"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Pipeline completed with status: ${currentBuild.currentResult}"

                // 发送通知到Slack
                if (currentBuild.currentResult == 'SUCCESS') {
                    slackSend(
                        color: 'good',
                        message: "✅ Pipeline ${JOB_NAME} #${BUILD_NUMBER} succeeded"
                    )
                } else if (currentBuild.currentResult == 'FAILURE') {
                    slackSend(
                        color: 'danger',
                        message: "❌ Pipeline ${JOB_NAME} #${BUILD_NUMBER} failed"
                    )
                }
            }
        }

        cleanup {
            dir('source') {
                // 清理临时文件
                sh '''
                    rm -rf node_modules/ .npm/ .yarn-cache/ coverage/ test-results/
                    rm -f kubeconfig.yaml
                '''
            }
        }
    }
}

// 辅助函数
def runNodeJSTests() {
    // 检测测试框架并运行测试
    if (fileExists('node_modules/.bin/jest')) {
        sh '''
            npx jest --coverage --coverageReporters=lcov,text,html --reporters=jest-junit --ci --maxWorkers=2
            mkdir -p ${TEST_RESULTS_DIR}
            cp junit.xml ${TEST_RESULTS_DIR}/ || true
        '''
    } else if (fileExists('node_modules/.bin/mocha')) {
        sh '''
            npx mocha --reporter json --reporter-option output=${TEST_RESULTS_DIR}/mocha.json || true
        '''
    } else if (fileExists('package.json')) {
        def packageJson = readJSON file: 'package.json'
        if (packageJson.scripts && packageJson.scripts.test) {
            sh 'npm test || true'
        } else {
            echo "No test configuration found"
        }
    }
}